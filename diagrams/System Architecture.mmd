}

class Room {
  +String roomID
  +String roomType
  +int guestNumber
  +String availabilityStatus
  +double price
  +String bookingID
  +bookRoom()
  +updateAvailabilityStatus()
  +getRoomDetails()
}

class API {
  +String url
  -String token
  +fetchRoomData()
  +fetchReservationData()
}

class Verification {
  -String userID
  +String passportPhoto
  +String selfiePhoto
  +String verificationStatus
  +uploadPassport()
  +uploadSelfiePhoto()
  +updateVerificationStatus()
}

User "1" --> "*" Reservation : makes
Reservation "1" --> "1" Room : reserves
