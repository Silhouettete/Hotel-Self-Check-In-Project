  +int PhoneNumber
  +String EmailAddress
  +LogIn()
  +CheckIn()
  +bookTheRoom()
}

class Reservation {
  +String bookingID
  +String roomName
  +int roomNumber
  +int numberOfGuest
  +String status
  +String paymentStatus
  +checkInReservation()
  +cancelReservation()
